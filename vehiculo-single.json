              "id": "w5e6f7a8",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"mv-price-card\">\n  <div class=\"mv-price-row\">\n    <span class=\"mv-price-label\">Precio en Alemania</span>\n    <span class=\"mv-price-orig\">[acf field='precio_alemania'] €</span>\n  </div>\n  <div class=\"mv-price-divider\"></div>\n  <div class=\"mv-price-row mv-price-main\">\n    <span class=\"mv-price-label\">Precio en España</span>\n    <span class=\"mv-price-es\">[acf field='precio_venta_espana'] €</span>\n  </div>\n</div>\n<style>\n.mv-price-card {\n  background: #fff;\n  border: 2px solid #195d6a;\n  border-radius: 10px;\n  padding: 20px 22px;\n  margin-bottom: 20px;\n}\n.mv-price-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 6px 0;\n}\n.mv-price-label {\n  font-size: 12px;\n  color: #777;\n  font-weight: 500;\n}\n.mv-price-orig {\n  font-size: 15px;\n  font-weight: 600;\n  color: #195d6a;\n}\n.mv-price-divider {\n  height: 1px;\n  background: #e5ebe9;\n  margin: 8px 0;\n}\n.mv-price-main .mv-price-es {\n  font-size: 26px;\n  font-weight: 800;\n  color: #539c88;\n}\n</style>"
