              "settings": {
                "html": "<div class=\"mv-hero-badges\">\n  <span class=\"mv-badge mv-badge-cat\">[acf field='categoria']</span>\n  <span class=\"mv-badge mv-badge-orig\">[acf field='origen']</span>\n  <span class=\"mv-badge mv-badge-est\">[acf field='estado']</span>\n</div>\n<style>\n.mv-hero-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }\n.mv-badge { display: inline-block; padding: 5px 14px; border-radius: 20px; font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: capitalize; }\n.mv-badge-cat { background: rgba(255,255,255,0.18); color: #fff; border: 1px solid rgba(255,255,255,0.35); }\n.mv-badge-orig { background: #feab70; color: #fff; }\n.mv-badge-est { background: #539c88; color: #fff; }\n</style>"
