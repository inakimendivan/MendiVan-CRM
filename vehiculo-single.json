              "id": "w4d5e6f7",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div class=\"mv-specs-grid\">\n  <div class=\"mv-spec\">\n    <strong>Año</strong>\n    <span>[acf field='anio']</span>\n  </div>\n  <div class=\"mv-spec\">\n    <strong>Kilómetros</strong>\n    <span>[acf field='km'] km</span>\n  </div>\n  <div class=\"mv-spec\">\n    <strong>Combustible</strong>\n    <span>[acf field='combustible']</span>\n  </div>\n  <div class=\"mv-spec\">\n    <strong>Cambio</strong>\n    <span>[acf field='cambio']</span>\n  </div>\n  <div class=\"mv-spec\">\n    <strong>Potencia</strong>\n    <span>[acf field='potencia_cv'] CV</span>\n  </div>\n  <div class=\"mv-spec\">\n    <strong>Color</strong>\n    <span>[acf field='color']</span>\n  </div>\n</div>\n<style>\n.mv-specs-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 12px;\n  margin-top: 4px;\n}\n.mv-spec {\n  background: #f0f4ed;\n  border-radius: 8px;\n  padding: 14px 16px;\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  border-left: 3px solid #539c88;\n}\n.mv-spec strong {\n  font-size: 10px;\n  text-transform: uppercase;\n  color: #195d6a;\n  letter-spacing: 0.06em;\n  font-weight: 600;\n}\n.mv-spec span {\n  font-size: 15px;\n  font-weight: 700;\n  color: #1a1a1a;\n  text-transform: capitalize;\n}\n@media (max-width: 768px) {\n  .mv-specs-grid { grid-template-columns: 1fr 1fr; }\n}\n</style>"
              }
            }
